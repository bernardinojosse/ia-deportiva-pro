name: Escaneo Automatico NuviCore

on:
  schedule:
    - cron: '0 */3 * * *'
  workflow_dispatch:

jobs:
  run-scraper:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - uses: actions/setup-python@v4
        with:
          python-version: '3.9'
      - name: Instalar dependencias
        run: pip install pandas requests beautifulsoup4 lxml
      - name: Ejecutar Scraper Total
        run: python main_scraper.py
      - name: Actualizar base de datos en GitHub
        run: |
          git config --global user.name "NuviCore-Bot"
          git config --global user.email "bot@nuvicore.com"
          git add campionati/*.csv
          git commit -m "Cuotas actualizadas automáticamente" || echo "Sin cambios"
          git push

